{
  "version": "1.0.0",
  "purpose": "Currency model for the Mono & DIV Economy Game treasury fiat allocation engine.",
  "principle": "Fiat reserves matter only if they preserve real, liquid, deployable purchasing power.",
  "defaultAllocationMode": "balanced",
  "baseCurrency": "USD",
  "displayCurrency": "USD",

  "allocationModes": {
    "balanced": {
      "label": "Balanced",
      "description": "Balanced automatic allocation across trust, liquidity, depth, return, and saturation.",
      "trustWeight": 0.28,
      "liquidityWeight": 0.2,
      "depthWeight": 0.27,
      "returnWeight": 0.15,
      "riskPenaltyWeight": 0.1
    },

    "safety_first": {
      "label": "Safety First",
      "description": "Prioritises high-trust, highly liquid currencies even if yields are lower.",
      "trustWeight": 0.38,
      "liquidityWeight": 0.27,
      "depthWeight": 0.2,
      "returnWeight": 0.05,
      "riskPenaltyWeight": 0.1
    },

    "yield_seeking": {
      "label": "Yield Seeking",
      "description": "Accepts more FX and political risk to seek higher effective returns.",
      "trustWeight": 0.2,
      "liquidityWeight": 0.14,
      "depthWeight": 0.19,
      "returnWeight": 0.34,
      "riskPenaltyWeight": 0.13
    },

    "liquidity_first": {
      "label": "Liquidity First",
      "description": "Prioritises immediately deployable support liquidity during stress.",
      "trustWeight": 0.3,
      "liquidityWeight": 0.38,
      "depthWeight": 0.18,
      "returnWeight": 0.04,
      "riskPenaltyWeight": 0.1
    }
  },

  "globalReferences": {
    "globalM2UsdReference": 120000000000000,
    "globalGdpUsdReference": 110000000000000,
    "maximumTreasuryFiatCapUsd": 100000000000000,
    "saturationWarningLevel": 100,
    "highSaturationWarningLevel": 150,
    "capitalControlWarningLevel": 30,
    "negativeRealReturnWarningLevel": -0.03
  },

  "currencyTiers": {
    "tier_1_high_trust": {
      "label": "Tier 1 High Trust",
      "description": "Deep, trusted, highly liquid reserve currencies.",
      "currencies": ["USD", "EUR", "CHF", "GBP", "JPY", "CAD", "AUD", "SGD"],
      "defaultWeightCap": 0.18,
      "trustFloor": 80
    },

    "tier_2_strong_secondary": {
      "label": "Tier 2 Strong Secondary",
      "description": "Strong secondary currencies with decent trust and usable liquidity.",
      "currencies": ["NOK", "SEK", "DKK", "NZD", "KRW", "PLN", "CZK", "ILS"],
      "defaultWeightCap": 0.08,
      "trustFloor": 70
    },

    "tier_3_higher_yield_growth": {
      "label": "Tier 3 Higher-Yield Growth",
      "description": "Higher-yield currencies with more FX, inflation, liquidity, or political risk.",
      "currencies": ["ZAR", "MXN", "BRL", "INR", "IDR", "MYR", "THB", "PHP", "CLP", "COP"],
      "defaultWeightCap": 0.05,
      "trustFloor": 45
    },

    "tier_4_large_restricted_special": {
      "label": "Tier 4 Large, Restricted, or Special",
      "description": "Large or strategically relevant currencies with meaningful restrictions or special risks.",
      "currencies": ["CNY", "AED", "SAR", "HKD"],
      "defaultWeightCap": 0.04,
      "trustFloor": 50
    }
  },

