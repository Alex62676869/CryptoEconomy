  "calculationNotes": {
    "effectiveUsdReturn": "nominalYield - expectedFxDecay - liquidityHaircut - saturationPenalty",
    "realReturn": "nominalYield - inflation - expectedFxDecay - liquidityHaircut - saturationPenalty",
    "saturationLevel": "usdEquivalent / softCapacityUsd",
    "localM2Share": "usdEquivalent / estimated local broad money",
    "liquidSupportUsd": "currency balance multiplied by liquidity, trust, and capital-control accessibility",
    "marginalAllocationScore": "trust + depth + liquidity + effective return - saturation - capital controls - concentration"
  },

  "displayColumns": [
    "code",
    "region",
    "tier",
    "usdEquivalent",
    "nominalYield",
    "inflation",
    "expectedFxDecay",
    "effectiveUsdReturn",
    "realReturn",
    "trustScore",
    "bankingDepthScore",
    "gdpDepthScore",
    "liquidityScore",
    "capitalControlPenalty",
    "saturationLevel",
    "localM2Share",
    "riskWarning"
  ]
}
