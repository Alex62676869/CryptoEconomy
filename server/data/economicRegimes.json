{
  "version": "1.0.0",
  "purpose": "Macro and market regime definitions for the Mono & DIV Economy Game.",
  "principle": "Economic regimes should shape demand, liquidity, volatility, trust, fiat usefulness, and scenario probability without replacing the core engine rules.",

  "defaultRegime": "calm_expansion",

  "regimeVariables": {
    "riskMood": {
      "values": ["risk_on", "neutral", "risk_off"],
      "description": "General market appetite for risk."
    },
    "recessionRisk": {
      "min": 0,
      "max": 1,
      "description": "Probability-like pressure representing economic slowdown fear."
    },
    "inflationFear": {
      "min": 0,
      "max": 1,
      "description": "Pressure from fear that fiat purchasing power is weakening."
    },
    "cryptoSentiment": {
      "min": 0,
      "max": 1,
      "description": "General market openness toward crypto-like monetary systems."
    },
    "regulationPressure": {
      "min": 0,
      "max": 1,
      "description": "Political, legal, and regulatory pressure against Mono and DIV."
    },
    "mediaAttention": {
      "min": 0,
      "max": 1,
      "description": "Public attention level. Attention can create demand but is not the same as adoption."
    },
    "bankingStress": {
      "min": 0,
      "max": 1,
      "description": "Stress in the traditional banking system."
    }
  },

