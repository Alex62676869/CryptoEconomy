  "transitionRules": {
    "risk_on_expansion": {
      "enterWhen": {
        "cryptoSentiment": { "min": 0.6 },
        "recessionRisk": { "max": 0.2 },
        "bankingStress": { "max": 0.2 }
      }
    },
    "crypto_euphoria": {
      "enterWhen": {
        "cryptoSentiment": { "min": 0.7 },
        "mediaAttention": { "min": 0.4 }
      }
    },
    "risk_off": {
      "enterWhen": {
        "cryptoSentiment": { "max": 0.35 }
      }
    },
    "recession_fear": {
      "enterWhen": {
        "recessionRisk": { "min": 0.55 }
      }
    },
    "inflation_fear": {
      "enterWhen": {
        "inflationFear": { "min": 0.6 }
      }
    },
    "banking_stress": {
      "enterWhen": {
        "bankingStress": { "min": 0.55 }
      }
    },
    "regulatory_pressure": {
      "enterWhen": {
        "regulationPressure": { "min": 0.55 }
      }
    },
    "treasury_stress": {
      "enterWhen": {
        "treasuryControlScore": { "max": 45 },
        "systemicTrust": { "max": 50 }
      }
    },
    "monetary_transition": {
      "enterWhen": {
        "fiatDisplacementIndex": { "min": 45 },
        "systemicTrust": { "min": 45 }
      }
    },
    "systemic_crisis": {
      "enterWhen": {
        "panicRisk": { "min": 0.5 },
        "systemicTrust": { "max": 35 }
      }
    }
  },

  "engineNotes": {
    "regimeSelection": "The scenario engine may calculate the current regime from market variables instead of loading this file directly in v1.",
    "regimeEffects": "Regime effects should be multipliers or biases. They should not directly overwrite balance sheets.",
    "multipleSignals": "When several regime signals are active, crisis and stress regimes should dominate calm regimes.",
    "meanReversion": "Macro variables should slowly drift back toward calm_expansion baselines unless scenarios or endogenous conditions keep them elevated.",
    "playerImpact": "The player cannot choose the regime directly, but treasury policy can make some regimes easier or harder to survive."
  }
}
