{
  "version": "1.0.0",
  "purpose": "Scenario family definitions for the Mono & DIV Economy Game.",
  "principle": "Scenario families group shocks by the economic channels they affect. Individual scenarios should inherit family defaults and then override specific effects.",

  "severityLevels": {
    "minor": {
      "label": "Minor",
      "description": "Small event. Should create movement but not dominate the economy.",
      "severityWeight": 1,
      "defaultDurationDays": {
        "min": 2,
        "max": 14
      },
      "defaultIntensityMultiplier": 0.6
    },

    "moderate": {
      "label": "Moderate",
      "description": "Meaningful event. Should affect several engines and be visible to the player.",
      "severityWeight": 2,
      "defaultDurationDays": {
        "min": 7,
        "max": 45
      },
      "defaultIntensityMultiplier": 1
    },

    "serious": {
      "label": "Serious",
      "description": "Strong event. Should test liquidity, trust, treasury execution, or adoption quality.",
      "severityWeight": 3,
      "defaultDurationDays": {
        "min": 14,
        "max": 90
      },
      "defaultIntensityMultiplier": 1.5
    },

    "severe": {
      "label": "Severe",
      "description": "Major stress event. Should create visible instability and expose weak treasury design.",
      "severityWeight": 4,
      "defaultDurationDays": {
        "min": 30,
        "max": 180
      },
      "defaultIntensityMultiplier": 2.2
    },

    "crisis": {
      "label": "Crisis",
      "description": "Systemic stress event. Should be rare outside brutal or historical chaos settings.",
      "severityWeight": 5,
      "defaultDurationDays": {
        "min": 60,
        "max": 365
      },
      "defaultIntensityMultiplier": 3
    }
  },

  "durationTypes": {
    "flash": {
      "label": "Flash",
      "description": "Very short event with sharp immediate effects.",
      "durationDays": {
        "min": 1,
        "max": 5
      },
      "recoveryShape": "fast_decay"
    },

    "short": {
      "label": "Short",
      "description": "Short market event or media cycle.",
      "durationDays": {
        "min": 5,
        "max": 21
      },
      "recoveryShape": "normal_decay"
    },

    "medium": {
      "label": "Medium",
      "description": "Multi-week event that can influence adoption and trust.",
      "durationDays": {
        "min": 21,
        "max": 90
      },
      "recoveryShape": "slow_decay"
    },

    "macro_regime": {
      "label": "Macro Regime",
      "description": "Longer economic regime that changes background conditions.",
      "durationDays": {
        "min": 90,
        "max": 365
      },
      "recoveryShape": "regime_persistence"
    },

    "structural_transition": {
      "label": "Structural Transition",
      "description": "Long transition that affects fiat usefulness, regulation, adoption, or monetary structure.",
      "durationDays": {
        "min": 180,
        "max": 1095
      },
      "recoveryShape": "partial_recovery"
    }
  },

  "families": {
    "promotion_attention": {
      "id": "promotion_attention",
      "label": "Promotion and Attention",
      "description": "Media attention, creator mentions, viral trends, hype cycles, and public awareness events.",
      "mainEnginesAffected": [
        "demandAdoptionEngine",
        "priceMarketEngine",
        "confidenceTrustEngine",
        "scenarioShockEngine"
      ],
      "commonSource": "exogenous",
      "defaultDurationType": "short",
      "defaultEffects": {
        "awarenessImpact": 0.8,
        "monoDemandImpact": 5,
        "divDemandImpact": 8,
        "volatilityImpact": 5,
        "mediaAttentionImpact": 0.08,
        "cryptoSentimentImpact": 0.04,
        "adoptionQualityImpact": -1
      },
      "positiveChannels": [
        "More awareness",
        "More public demand",
        "Faster trial adoption",
        "Potential liquidity increase"
      ],
      "negativeChannels": [
        "Lower adoption quality if attention is speculative",
        "DIV overheating risk",
        "Volatility from hype",
        "Regulatory attention if promotion becomes large"
      ],
      "difficultyBias": {
        "sandbox": 1,
        "normal": 1,
        "hard": 1.15,
        "brutal": 1.3,
        "historical_chaos": 1.5
      },
      "exampleScenarios": [
        "Viral promotion wave",
        "Major creator endorsement",
        "Media backlash",
        "Search interest spike",
        "Influencer misinformation cycle"
      ]
    },

