  "familyInteractionRules": {
    "promotion_attention + market_structure": {
      "description": "Hype with weak liquidity creates volatility and bubble risk.",
      "effects": {
        "volatilityImpact": 8,
        "divSellPressureImpact": 4,
        "adoptionQualityImpact": -3
      }
    },

    "promotion_attention + dividend": {
      "description": "Attention plus dividend expectations can create DIV overheating.",
      "effects": {
        "divDemandImpact": 12,
        "volatilityImpact": 8,
        "divTrustImpact": -2
      }
    },

    "macro + market_structure": {
      "description": "Risk-off macro and weak liquidity amplify downside moves.",
      "effects": {
        "liquidityImpact": -8,
        "volatilityImpact": 10,
        "panicRiskImpact": 4
      }
    },

    "fiat_inflation + adoption": {
      "description": "Fiat weakness plus real adoption accelerates high-quality Mono usage.",
      "effects": {
        "monoDemandImpact": 8,
        "savingsAdoptionImpact": 4,
        "paymentAdoptionImpact": 2
      }
    },

    "fiat_inflation + treasury_trust": {
      "description": "Fiat weakness is dangerous when treasury fiat reserves are already questioned.",
      "effects": {
        "fiatTrustImpact": -8,
        "runRiskImpact": 5,
        "liquidityTrustImpact": -4
      }
    },

    "regulation_political + fiat_displacement": {
      "description": "High fiat displacement attracts government resistance.",
      "effects": {
        "governmentResistanceImpact": 8,
        "bankingFrictionImpact": 6,
        "regulatoryTrustImpact": -6
      }
    },

    "banking_financial + mono_high_trust": {
      "description": "Banking stress can strengthen Mono if Mono trust is already high.",
      "effects": {
        "monoDemandImpact": 12,
        "savingsAdoptionImpact": 5,
        "monoTrustImpact": 3
      }
    },

    "banking_financial + mono_low_trust": {
      "description": "Banking stress can hurt the whole system if Mono trust is weak.",
      "effects": {
        "monoSellPressureImpact": 10,
        "liquidityTrustImpact": -8,
        "panicRiskImpact": 6
      }
    }
  },

  "engineNotes": {
    "familyDefaults": "Individual scenarios should start from family defaults, then override effect values.",
    "stacking": "Multiple active families should be allowed, but scenario clustering should increase volatility and panic risk.",
    "difficulty": "Difficulty should adjust frequency, intensity, clustering, and recovery, not change the meaning of scenario effects.",
    "endogenousScenarios": "Endogenous scenarios should trigger from state conditions such as inventory stress, overheating, fiat weakness, and support failure.",
    "exogenousScenarios": "Exogenous scenarios should represent outside-world events such as recession, regulation, banking stress, media attention, or competitor activity."
  }
}
