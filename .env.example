# Mono & DIV Economy Game

NODE_ENV=development

# Server
PORT=3000
HOST=0.0.0.0

# Optional Postgres persistence for future db layer
# The current v1 server can run without a database.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mono_div_game

# Optional runtime tuning
TICK_MS=1000
SIMULATED_DAYS_PER_TICK=1

# Fly.io / deployment
# Set this in GitHub Actions secrets, not here:
# FLY_API_TOKEN=
